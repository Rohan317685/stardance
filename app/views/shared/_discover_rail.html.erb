<%# Discover rail — shown on the right of profile + project pages. %>
<%# Placeholder content for now until the underlying features ship. %>
<aside class="profile-layout__aside" aria-label="Discover">
  <div class="right-rail__search">
    <input type="text" class="right-rail__search-input" placeholder="Search…" aria-label="Search" disabled>
    <%= inline_svg_tag "icons/search.svg", class: "right-rail__search-icon" %>
  </div>

  <section class="right-rail__section" aria-label="Popular projects this week">
    <h2 class="right-rail__heading">Popular projects this week</h2>
    <div class="right-rail__placeholder right-rail__placeholder--tall"></div>
  </section>

  <section class="right-rail__section" aria-label="Sidequests for you">
    <h2 class="right-rail__heading">Sidequests for you</h2>
    <div class="right-rail__placeholder"></div>
    <div class="right-rail__placeholder"></div>
  </section>

  <section class="right-rail__section" aria-label="Stardance updates">
    <h2 class="right-rail__heading">Stardance updates</h2>
    <div class="right-rail__placeholder"></div>
    <div class="right-rail__placeholder"></div>
  </section>
</aside>
